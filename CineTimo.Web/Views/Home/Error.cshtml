@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <h1 class="display-1 text-danger"><i class="bi bi-exclamation-triangle"></i></h1>
    <h2 class="mb-3">Something went wrong</h2>
    <p class="text-muted">Please try again later or return to the homepage.</p>
    <a asp-action="Index" class="btn btn-green">
        <i class="bi bi-house"></i> Go Home
    </a>
</div>
