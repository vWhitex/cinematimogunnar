@model CineTimo.Core.Models.Room
@{
    ViewData["Title"] = "Edit Room";
    var cinemas = ViewBag.Cinemas as List<CineTimo.Core.Models.Cinema> ?? new List<CineTimo.Core.Models.Cinema>();
}

<h1 class="display-6 mb-4"><i class="bi bi-pencil"></i> Edit Room</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="EditRoom" asp-route-id="@Model.Id">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="CinemaId" class="form-label">Cinema</label>
                <select asp-for="CinemaId" class="form-select" required>
                    @foreach (var cinema in cinemas)
                    {
                        <option value="@cinema.Id" selected="@(Model.CinemaId == cinema.Id)">
                            @cinema.Name (@cinema.City)
                        </option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Capacity" class="form-label">Capacity (seats)</label>
                <input asp-for="Capacity" type="number" class="form-control" min="1" required />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-green">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
                <a asp-action="Rooms" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
