@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="display-6 mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h1>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-gradient-green text-white h-100">
            <div class="card-body text-center">
                <i class="bi bi-film display-4"></i>
                <h2 class="mt-3">@ViewBag.FilmCount</h2>
                <p class="mb-0">Films</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white h-100">
            <div class="card-body text-center">
                <i class="bi bi-building display-4"></i>
                <h2 class="mt-3">@ViewBag.CinemaCount</h2>
                <p class="mb-0">Cinemas</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white h-100">
            <div class="card-body text-center">
                <i class="bi bi-grid-3x3 display-4"></i>
                <h2 class="mt-3">@ViewBag.RoomCount</h2>
                <p class="mb-0">Rooms</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white h-100">
            <div class="card-body text-center">
                <i class="bi bi-clock display-4"></i>
                <h2 class="mt-3">@ViewBag.ShowtimeCount</h2>
                <p class="mb-0">Showtimes</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-dark-green text-white">
                <i class="bi bi-info-circle"></i> Quick Actions
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <a asp-action="CreateFilm" class="btn btn-outline-green w-100">
                            <i class="bi bi-plus-circle"></i> Add Film
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-action="CreateCinema" class="btn btn-outline-green w-100">
                            <i class="bi bi-plus-circle"></i> Add Cinema
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-action="CreateRoom" class="btn btn-outline-green w-100">
                            <i class="bi bi-plus-circle"></i> Add Room
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a asp-action="CreateShowtime" class="btn btn-outline-green w-100">
                            <i class="bi bi-plus-circle"></i> Add Showtime
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
