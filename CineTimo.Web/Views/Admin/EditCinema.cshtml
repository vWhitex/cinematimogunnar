@model CineTimo.Core.Models.Cinema
@{
    ViewData["Title"] = "Edit Cinema";
}

<h1 class="display-6 mb-4"><i class="bi bi-pencil"></i> Edit Cinema</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="EditCinema" asp-route-id="@Model.Id">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="City" class="form-label">City</label>
                <select asp-for="City" class="form-select" required>
                    <option value="Tallinn" selected="@(Model.City == "Tallinn")">Tallinn</option>
                    <option value="Tartu" selected="@(Model.City == "Tartu")">Tartu</option>
                    <option value="Pärnu" selected="@(Model.City == "Pärnu")">Pärnu</option>
                    <option value="Haapsalu" selected="@(Model.City == "Haapsalu")">Haapsalu</option>
                    <option value="Narva" selected="@(Model.City == "Narva")">Narva</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-green">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
                <a asp-action="Cinemas" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
