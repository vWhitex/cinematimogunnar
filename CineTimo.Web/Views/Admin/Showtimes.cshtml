@model List<AdminShowtimeViewModel>
@{
    ViewData["Title"] = "Manage Showtimes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6"><i class="bi bi-clock"></i> Showtimes</h1>
    <a asp-action="CreateShowtime" class="btn btn-green">
        <i class="bi bi-plus-circle"></i> Add Showtime
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Film</th>
            <th>Room</th>
            <th>Cinema</th>
            <th>Start Time</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Film?.Title</td>
                <td>@item.Room?.Name</td>
                <td>@item.Cinema?.Name <span class="text-muted">(@item.Cinema?.City)</span></td>
                <td>
                    @item.Showtime.StartTime.ToString("MMM d, yyyy")
                    <br>
                    <span class="badge bg-secondary">@item.Showtime.StartTime.ToString("HH:mm")</span>
                </td>
                <td><span class="badge bg-green">@item.Showtime.Price.ToString("C")</span></td>
                <td>
                    <a asp-action="EditShowtime" asp-route-id="@item.Showtime.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="DeleteShowtime" asp-route-id="@item.Showtime.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Are you sure you want to delete this showtime?')">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
