@model CineTimo.Core.Models.Film
@{
    ViewData["Title"] = "Edit Film";
}

<h1 class="display-6 mb-4"><i class="bi bi-pencil"></i> Edit Film</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="EditFilm" asp-route-id="@Model.Id">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Title</label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="DurationMinutes" class="form-label">Duration (minutes)</label>
                <input asp-for="DurationMinutes" type="number" class="form-control" min="1" required />
            </div>
            <div class="mb-3">
                <label asp-for="Genre" class="form-label">Genre</label>
                <input asp-for="Genre" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="PosterUrl" class="form-label">Poster URL</label>
                <input asp-for="PosterUrl" class="form-control" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-green">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
                <a asp-action="Films" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
