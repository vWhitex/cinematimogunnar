@model List<CineTimo.Core.Models.Cinema>
@{
    ViewData["Title"] = "Manage Cinemas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6"><i class="bi bi-building"></i> Cinemas</h1>
    <a asp-action="CreateCinema" class="btn btn-green">
        <i class="bi bi-plus-circle"></i> Add Cinema
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>City</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cinema in Model)
        {
            <tr>
                <td>@cinema.Name</td>
                <td><span class="badge bg-secondary">@cinema.City</span></td>
                <td>
                    <a asp-action="EditCinema" asp-route-id="@cinema.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="DeleteCinema" asp-route-id="@cinema.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Are you sure you want to delete this cinema?')">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
