@model List<RoomViewModel>
@{
    ViewData["Title"] = "Manage Rooms";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6"><i class="bi bi-grid-3x3"></i> Rooms</h1>
    <a asp-action="CreateRoom" class="btn btn-green">
        <i class="bi bi-plus-circle"></i> Add Room
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Cinema</th>
            <th>Capacity</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Room.Name</td>
                <td>@item.Cinema?.Name <span class="text-muted">(@item.Cinema?.City)</span></td>
                <td>@item.Room.Capacity seats</td>
                <td>
                    <a asp-action="EditRoom" asp-route-id="@item.Room.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="DeleteRoom" asp-route-id="@item.Room.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Are you sure you want to delete this room?')">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
