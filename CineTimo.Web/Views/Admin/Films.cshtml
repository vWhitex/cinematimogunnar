@model List<CineTimo.Core.Models.Film>
@{
    ViewData["Title"] = "Manage Films";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6"><i class="bi bi-film"></i> Films</h1>
    <a asp-action="CreateFilm" class="btn btn-green">
        <i class="bi bi-plus-circle"></i> Add Film
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Poster</th>
            <th>Title</th>
            <th>Genre</th>
            <th>Duration</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model)
        {
            <tr>
                <td><img src="@film.PosterUrl" alt="@film.Title" style="width: 50px; height: 75px; object-fit: cover;" class="rounded"></td>
                <td>@film.Title</td>
                <td><span class="badge bg-green">@film.Genre</span></td>
                <td>@film.DurationMinutes min</td>
                <td>
                    <a asp-action="EditFilm" asp-route-id="@film.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="DeleteFilm" asp-route-id="@film.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Are you sure you want to delete this film?')">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
